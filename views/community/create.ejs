<!-- File: views/community/create.ejs -->
<% locals.pageTitle = 'Community AVS - Create Post'; %>

<div class="container" style="max-width: 860px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Community AVS</h2>
        <a href="/profile?tab=community" class="btn btn-outline-secondary btn-sm">Back to Feed</a>
    </div>

    <div class="card">
        <div class="card-body">
            <form action="/community/create" method="POST" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Poster (HR)</label>
                    <select name="poster_code" class="form-select">
                        <option value="">Select HR Staff</option>
                        <% if (typeof hr_employees !== 'undefined' && hr_employees) { %>
                            <% hr_employees.forEach(function(emp) { %>
                                <option value="<%= emp.employee_code %>">
                                    <%= emp.employee_name %> - <%= emp.title %>
                                </option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Content</label>
                    <textarea name="content" class="form-control" rows="5" required></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Post Type</label>
                    <select name="post_type" class="form-select">
                        <option value="announcement">Announcement</option>
                        <option value="promotion">Promotion</option>
                        <option value="job">Job</option>
                        <option value="news">News</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Images</label>
                    <input type="file" name="images" class="form-control" multiple accept="image/*">
                    <div class="text-muted small mt-1">You can choose multiple images.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Publish Post</button>
                    <a href="/profile?tab=community" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
