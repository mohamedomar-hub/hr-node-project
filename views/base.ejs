                      <span id="notifBadge" class="notification-badge" style="<%= (locals.notificationsUnreadCount || 0) > 0 ? '' : 'display:none;' %>"><%= (locals.notificationsUnreadCount || 0) > 99 ? '99+' : '+' + (locals.notificationsUnreadCount || 0) %></span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-0 notification-menu" aria-labelledby="notifDropdownBtn">
                      <div class="px-3 py-3 border-bottom d-flex justify-content-between align-items-center notification-menu-header">
                        <div class="fw-semibold">Notifications</div>
                        <a class="small text-decoration-none fw-semibold" href="/notifications">View all</a>
                      </div>
                      <div id="notifList" class="list-group list-group-flush notification-menu-list">
                        <div class="px-3 py-3 text-muted small">Open to load notifications…</div>
                      </div>
                      <div class="px-3 py-2 border-top d-flex justify-content-between align-items-center notification-menu-footer">
                        <a class="small text-decoration-none fw-semibold" href="/notifications/mark_all">Mark all read</a>
                        <span class="small text-muted">Unread: <span id="notifUnreadText"><%= locals.notificationsUnreadCount || 0 %></span></span>
