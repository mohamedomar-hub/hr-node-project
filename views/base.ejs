<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('sidebar');
    const content = document.getElementById('content');
    if (toggleBtn && sidebar && content) {
        toggleBtn.addEventListener('click', function() {
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle('active-mobile');
                return;
            }
            sidebar.classList.toggle('collapsed');
            content.classList.toggle('expanded');
            toggleBtn.classList.toggle('moved');
            const icon = toggleBtn.querySelector('i');
            if (sidebar.classList.contains('collapsed')) {
                icon.classList.remove('fa-bars');
                icon.classList.add('fa-chevron-right');
            } else {
                icon.classList.remove('fa-chevron-right');
                icon.classList.add('fa-bars');
            }
        });
        const currentPath = window.location.pathname.replace(/\/+$/, '') || '/';
        const currentFullPath = `${currentPath}${window.location.search || ''}`;
        const links = Array.from(sidebar.querySelectorAll('.nav-link[href]'));
        let activeLink = null;
        links.forEach(function(link) {
            if (!link.getAttribute('title')) {
                link.setAttribute('title', link.textContent.trim());
            }
            const rawHref = link.getAttribute('href') || '';
            const hrefParts = rawHref.split('?');
            const href = (hrefParts[0] || '').replace(/\/+$/, '') || '/';
            if (href === '/logout') return;
            if (rawHref.includes('?') && currentFullPath === rawHref) {
                activeLink = link;
                return;
            }
            if (currentPath === href || (href !== '/' && currentPath.startsWith(href))) {
                if (!activeLink || rawHref.length > (activeLink.getAttribute('href') || '').length) {
                    activeLink = link;
                }
            }
        });
        if (activeLink) {
            activeLink.classList.add('active');
        }

        const sidebarSearch = document.getElementById('sidebarSearch');
        if (sidebarSearch) {
          sidebarSearch.addEventListener('input', function() {
            const q = sidebarSearch.value.trim().toLowerCase();
            const items = Array.from(sidebar.querySelectorAll('.nav-item'));
            items.forEach(function(item) {
              const link = item.querySelector('.nav-link');
              if (!link) return;
              const text = link.textContent.trim().toLowerCase();
              item.style.display = !q || text.includes(q) ? '' : 'none';
            });
            Array.from(sidebar.querySelectorAll('.sidebar-group-title')).forEach(function(title) {
              let node = title.nextElementSibling;
              let hasVisible = false;
              while (node && !node.classList.contains('sidebar-group-title')) {
                if (node.classList.contains('nav-item') && node.style.display !== 'none') {
                  hasVisible = true;
                  break;
                }
                node = node.nextElementSibling;
              }
              title.style.display = !q || hasVisible ? '' : 'none';
            });
          });
        }
    }

    const notifBtn = document.getElementById('notifDropdownBtn');
    const notifBadge = document.getElementById('notifBadge');
    const sidebarNotifBadge = document.getElementById('sidebarNotifBadge');
    const notifList = document.getElementById('notifList');
    const notifUnreadText = document.getElementById('notifUnreadText');

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function setNotifCount(count) {
      const n = Number(count) || 0;
      const label = n > 99 ? '99+' : `+${n}`;
      if (notifUnreadText) notifUnreadText.textContent = String(n);
      [notifBadge, sidebarNotifBadge].forEach((badge) => {
        if (!badge) return;
        if (n > 0) {
          badge.style.display = '';
          badge.textContent = label;
        } else {
          badge.style.display = 'none';
          badge.textContent = '+0';
        }
      });
    }

    function renderNotifList(items) {
      if (!notifList) return;
      const rows = Array.isArray(items) ? items : [];
      if (rows.length === 0) {
        notifList.innerHTML = '<div class="px-3 py-3 text-muted small">No notifications.</div>';
        return;
      }

      notifList.innerHTML = rows.slice(0, 8).map((r) => {
        const created = r.created_at ? String(r.created_at).replace('T', ' ').slice(0, 19) : '';
        const cls = r.is_read ? '' : 'unread';
        return `
          <a class="list-group-item list-group-item-action notification-row ${cls}" href="/notifications/open/${encodeURIComponent(r.id)}">
            <span class="notification-row-icon"><i class="fas fa-bell"></i></span>
            <div>
              <div class="notification-row-message">${escapeHtml(r.message || '')}</div>
              <div class="notification-row-time">${escapeHtml(created)}</div>
            </div>
          </a>
        `;
      }).join('');
    }

    let notifRefreshing = false;
    async function refreshNotifications() {
      if (!notifBtn || !notifList) return;
      if (notifRefreshing) return;
      notifRefreshing = true;
      try {
        const res = await fetch('/notifications/api/summary', { headers: { 'Accept': 'application/json' } });
        if (!res.ok) return;
        const data = await res.json();
        setNotifCount(data.unreadCount || 0);
        renderNotifList(data.recent || []);
      } catch (e) {
        // ignore
      } finally {
        notifRefreshing = false;
      }
    }

    if (notifBtn) {
      notifBtn.addEventListener('click', refreshNotifications);
      refreshNotifications();
      setInterval(refreshNotifications, 60000);
    }
});
</script>
</body>
</html>
