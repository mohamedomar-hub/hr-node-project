<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HR System - <%= typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' %></title>
<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
    --app-bg: #f3f7fb;
    --panel-bg: rgba(255, 255, 255, 0.96);
    --panel-border: #dce6f2;
    --sidebar-bg: #1f3352;
    --sidebar-bg-alt: #182a43;
    --text-main: #10213a;
    --text-soft: #64748b;
    --line-soft: #e6edf5;
    --primary: #2563eb;
    --primary-dark: #1d4ed8;
    --secondary: #475569;
    --success: #0f766e;
    --danger: #dc2626;
    --warning: #d97706;
    --shadow-lg: 0 22px 48px rgba(15, 23, 42, 0.10);
    --shadow-md: 0 12px 28px rgba(15, 23, 42, 0.08);
}
body {
    background: linear-gradient(180deg, #eef4fb 0%, #f8fbff 42%, #f4f7fb 100%);
    color: var(--text-main);
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow-x: auto; 
    margin: 0;
    padding: 0;
}
/* Sidebar Styles */
.sidebar {
    width: 272px;
    height: calc(100vh - 36px);
    background: linear-gradient(180deg, var(--sidebar-bg) 0%, var(--sidebar-bg-alt) 100%);
    color: white;
    position: fixed;
    top: 18px;
    left: 16px;
    transition: all 0.3s;
    z-index: 1000;
    padding: 18px 14px 14px;
    display: flex;
    flex-direction: column;
    border-radius: 28px;
    box-shadow: 0 26px 60px rgba(15, 23, 42, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow-y: auto;
}
.sidebar.collapsed {
    margin-left: 0;
    transform: none;
    width: 88px;
    padding: 18px 10px 14px;
    overflow-y: hidden;
}
.sidebar.collapsed .user-info,
.sidebar.collapsed .sidebar-footer {
    display: none;
}
.sidebar.collapsed .nav {
    gap: 8px;
}
.sidebar.collapsed a {
    justify-content: center;
    gap: 0;
    padding: 14px 0;
    margin: 0 2px;
    font-size: 0;
}
.sidebar.collapsed a i {
    width: auto;
    font-size: 1.08rem;
    margin: 0 !important;
}
.sidebar .nav {
    gap: 6px;
}
.sidebar-search {
    position: sticky;
    top: 0;
    z-index: 2;
    padding: 0 6px 10px;
    background: linear-gradient(180deg, var(--sidebar-bg) 0%, rgba(31, 51, 82, 0.92) 100%);
}
.sidebar-search .input-group-text,
.sidebar-search .form-control {
    border-color: rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
}
.sidebar-search .form-control::placeholder {
    color: #cbd5e1;
}
.sidebar-group {
    margin: 8px 4px 4px;
    padding: 12px 0 6px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}
.sidebar-group:first-child {
    border-top: 0;
    padding-top: 0;
}
.sidebar-group-title {
    padding: 0 10px 7px;
    color: #9fb2c8;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}
.sidebar a {
    color: #ecf0f1;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    margin: 0 4px;
    transition: 0.25s ease;
    border-radius: 16px;
    border: 1px solid transparent;
    font-weight: 500;
    white-space: nowrap;
}
.sidebar a i {
    width: 18px;
    text-align: center;
    font-size: 0.95rem;
}
.sidebar a:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.08);
    transform: translateX(2px);
}
.sidebar a.active {
    background: linear-gradient(135deg, #ffffff 0%, #edf5ff 100%);
    color: var(--sidebar-bg);
    border-color: rgba(255, 255, 255, 0.72);
    box-shadow: 0 16px 30px rgba(10, 19, 34, 0.28);
    font-weight: 800;
    transform: translateX(4px);
}
.sidebar a.active i {
    color: var(--primary);
}
.nav-count-badge {
    margin-left: auto;
    min-width: 24px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 7px;
    border-radius: 999px;
    background: #f59e0b;
    color: #111827;
    font-size: 0.72rem;
    font-weight: 900;
    box-shadow: 0 8px 18px rgba(245, 158, 11, 0.25);
}
.sidebar.collapsed .sidebar-search,
.sidebar.collapsed .sidebar-group-title {
    display: none;
}
.sidebar.collapsed .sidebar-group {
    margin: 7px 0;
    padding: 0;
    border-top: 0;
}
.sidebar.collapsed .nav-count-badge {
    position: absolute;
    top: 5px;
    right: 8px;
    min-width: 19px;
    height: 19px;
    padding: 0 5px;
    font-size: 0.64rem;
}
.sidebar .user-info {
    padding: 18px 16px;
    margin: 0 6px 18px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
}
.sidebar .user-info h5 {
    font-size: 1.08rem;
    font-weight: 700;
}
.sidebar .user-info small {
    color: #b9c7d8 !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
}
.sidebar .nav-item.mt-4 {
    margin-top: 18px !important;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}
.sidebar .nav-link.text-danger {
    color: #fecaca !important;
}
.sidebar .nav-link.text-danger:hover {
    color: #ffffff !important;
    background: rgba(220, 38, 38, 0.18);
    border-color: rgba(248, 113, 113, 0.18);
}
.sidebar-footer {
    margin: 18px 6px 6px;
    padding: 16px;
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
    transition: all 0.3s;
    border-radius: 22px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
}
.sidebar-footer img {
    width: 100%;
    height: auto;
    max-height: 138px;
    opacity: 0.94;
    object-fit: contain;
    display: block;
}
.main-content {
    margin-left: 304px;
    padding: 26px 28px 36px;
    transition: all 0.3s;
    min-height: 100vh;
    overflow-x: visible; 
}
.main-content.expanded { margin-left: 120px; }
.top-navbar {
    background: var(--panel-bg);
    box-shadow: var(--shadow-md);
    padding: 8px 28px;
    margin-bottom: 20px;
    border-radius: 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 156px;
    border: 1px solid var(--panel-border);
    backdrop-filter: blur(10px);
}
.top-navbar .brand-logo {
    height: 100%;
    display: flex;
    align-items: center;
    flex: 1 1 auto;
    min-width: 0;
}
.top-navbar .brand-logo img {
    height: 118px;
    width: auto;
    max-width: min(100%, 760px);
    margin-right: 15px;
    object-fit: contain;
    object-position: left center;
    display: block;
    filter: drop-shadow(0 6px 14px rgba(15, 23, 42, 0.08));
}
.top-navbar .fw-bold {
    font-size: 1rem;
    color: var(--text-main);
}
.top-navbar small {
    color: var(--text-soft) !important;
}
.page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 26px;
    margin-bottom: 24px;
    border-radius: 24px;
    background: var(--panel-bg);
    border: 1px solid var(--panel-border);
    box-shadow: var(--shadow-md);
}
.page-header .page-label {
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--primary-dark);
}
.page-header .page-title {
    margin: 6px 0 0;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--text-main);
}
.main-content .container,
.main-content .container-fluid {
    max-width: 100%;
}
.main-content h2,
.main-content h3,
.main-content h4 {
    color: var(--text-main);
    font-weight: 700;
}
.main-content p,
.main-content label,
.main-content .text-muted {
    color: var(--text-soft);
}
.alert {
    margin-bottom: 20px;
    border: none;
    border-radius: 18px;
    box-shadow: var(--shadow-md);
}
.card {
    border: 1px solid var(--panel-border);
    border-radius: 24px;
    box-shadow: var(--shadow-md);
    background: rgba(255, 255, 255, 0.98);
    overflow: hidden;
}
.card-header {
    padding: 18px 22px;
    border-bottom: 1px solid var(--line-soft);
    background: #f7faff;
    font-weight: 700;
}
.card-header:first-child {
    border-radius: 24px 24px 0 0;
}
.card-body {
    padding: 22px;
}
.table-responsive {
    border: 1px solid var(--line-soft);
    border-radius: 18px;
    overflow-x: auto;
    background: #ffffff;
    width: 100%;
}
.table {
    margin-bottom: 0;
    vertical-align: middle;
    min-width: 100%;
}
.table thead th {
    padding: 16px 18px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #475569;
    background: #f7faff !important;
    border-bottom: 1px solid #dbe5f0;
    white-space: nowrap;
}
.table tbody td {
    padding: 16px 18px;
    color: var(--text-main);
    border-color: var(--line-soft);
    white-space: nowrap;
}
.table-hover tbody tr:hover,
.table-striped tbody tr:nth-of-type(odd) {
    background-color: #fafcff;
}
.form-label {
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.55rem;
}
.form-control,
.form-select {
    min-height: 48px;
    padding: 0.75rem 1rem;
    border-radius: 14px;
    border: 1px solid #d7e2ef;
    background: #fcfdff;
    box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.03);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
}
textarea.form-control {
    min-height: 110px;
}
.form-control-sm,
.form-select-sm {
    min-height: 42px;
    padding: 0.62rem 0.9rem;
    border-radius: 12px;
    font-size: 0.92rem;
}
.form-control:focus,
.form-select:focus {
    border-color: rgba(37, 99, 235, 0.45);
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
}
.btn {
    border: none;
    border-radius: 14px;
    padding: 0.76rem 1.2rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
}
.btn:hover {
    transform: translateY(-1px);
}
.btn-sm {
    border-radius: 12px;
    padding: 0.5rem 0.82rem;
}
.btn-primary,
.bg-primary {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
    border-color: var(--primary-dark) !important;
    color: #ffffff !important;
}
.btn-success,
.bg-success {
    background: linear-gradient(135deg, #0f766e 0%, #0b5f59 100%) !important;
    border-color: #0b5f59 !important;
    color: #ffffff !important;
}
.btn-secondary,
.bg-secondary {
    background: linear-gradient(135deg, #64748b 0%, #475569 100%) !important;
    border-color: #475569 !important;
    color: #ffffff !important;
}
.btn-danger,
.bg-danger {
    background: linear-gradient(135deg, #ef4444 0%, var(--danger) 100%) !important;
    border-color: var(--danger) !important;
    color: #ffffff !important;
}
.btn-warning,
.bg-warning {
    background: linear-gradient(135deg, #f59e0b 0%, var(--warning) 100%) !important;
    border-color: var(--warning) !important;
    color: #ffffff !important;
}
.badge {
    border-radius: 999px;
    padding: 0.55em 0.8em;
    font-weight: 600;
}
.toggle-btn {
    position: fixed;
    top: 30px;
    left: 286px;
    z-index: 1001;
    background: #ffffff;
    color: var(--sidebar-bg);
    border: 1px solid var(--panel-border);
    padding: 10px 13px;
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: var(--shadow-md);
}
.toggle-btn.moved {
    left: 102px;
}
.nav-notification-link {
    position: relative;
}
.nav-notification-badge {
    margin-left: auto;
    min-width: 24px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 7px;
    border-radius: 999px;
    background: #dc2626;
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 800;
    box-shadow: 0 8px 18px rgba(220, 38, 38, 0.32);
}
.sidebar.collapsed .nav-notification-badge {
    position: absolute;
    top: 5px;
    right: 8px;
    min-width: 19px;
    height: 19px;
    padding: 0 5px;
    font-size: 0.64rem;
}
.notification-button {
    width: 46px;
    height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: #f8fafc !important;
    color: #10213a !important;
    border: 1px solid #dbe5f0 !important;
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
}
.notification-button:hover {
    background: #ffffff !important;
}
.notification-badge {
    position: absolute;
    top: -7px;
    right: -9px;
    min-width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 7px;
    border: 2px solid #ffffff;
    border-radius: 999px;
    background: #dc2626;
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
    box-shadow: 0 10px 22px rgba(220, 38, 38, 0.35);
}
.notification-menu {
    width: min(440px, calc(100vw - 32px));
    border: 1px solid #dbe5f0;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 22px 46px rgba(15, 23, 42, 0.18);
}
.notification-menu-header,
.notification-menu-footer {
    background: #f8fbff;
}
.notification-menu-list {
    max-height: 360px;
    overflow-y: auto;
}
.notification-row {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 11px;
    padding: 13px 15px;
    border-left: 4px solid transparent;
}
.notification-row.unread {
    background: #fff7f7;
    border-left-color: #dc2626;
}
.notification-row-icon {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: #eef4ff;
    color: #2563eb;
}
.notification-row.unread .notification-row-icon {
    background: #fee2e2;
    color: #dc2626;
}
.notification-row-message {
    color: #10213a;
    font-size: 0.86rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-clamp: 2; 
}
.notification-row-time {
    margin-top: 5px;
    color: #64748b;
    font-size: 0.72rem;
}
@media (max-width: 768px) {
    .sidebar {
        width: calc(100vw - 32px);
        height: calc(100vh - 32px);
        top: 16px;
        left: 16px;
        transform: translateX(calc(-100% - 24px));
    }
    .sidebar.active-mobile {
        transform: translateX(0);
    }
    .main-content {
        margin-left: 0;
        padding: 82px 16px 24px;
    }
    .top-navbar {
        height: auto;
        min-height: 112px;
        padding: 14px 18px;
        gap: 12px;
        flex-wrap: wrap;
    }
    .top-navbar .brand-logo img {
        height: 72px;
        max-width: min(100%, 280px);
        margin-right: 0;
    }
    .page-header {
        padding: 18px 20px;
    }
    .toggle-btn {
        top: 22px;
        left: 16px;
    }
}
</style>
</head>
<body>
<%
var isAuthPage = typeof isAuthPage !== 'undefined' ? isAuthPage : false;
%>
<% if (!isAuthPage) { %>
<button class="toggle-btn" id="sidebarToggle"><i class="fas fa-bars"></i></button>
<% } %>
<div class="container-fluid p-0">
    <div class="row g-0">
        <% if (!isAuthPage && typeof user !== 'undefined' && user) {
            var role = (user.title || '').toUpperCase();
            var hideLeavesRoles = ['MR', 'DM', 'AM', 'HR'];
            var showLeavesLink = !hideLeavesRoles.includes(role);
            
            var hasHrMenu = locals.hasPermission('dashboard') ||
                locals.hasPermission('hr_inbox') ||
                locals.hasPermission('hr_manager') ||
                locals.hasPermission('reports') ||
                locals.hasPermission('employee_photos') ||
                locals.hasPermission('ask_employees') ||
                locals.hasPermission('recruitment') ||
                locals.hasPermission('personal_email') ||
                locals.hasPermission('employee_development');
            var hasFinanceMenu = locals.hasPermission('expenses_report') || locals.hasPermission('salary_report');
            
            // تعريف الأدوار الجديدة التي تحتاج لموافقة الإجازات
            var managerLeaveRoles = [
                'SALES SV', 
                'PERFORMANCE EXCELLENCE MANAGER', 
                'HR & TRAINING MANAGER', 
                'SFE MANAGER', 
                'DIRECT SALES MANAGER', 
                'OPERATION SUPERVISOR'
            ];
            var isManagerForLeaves = managerLeaveRoles.includes(role);

            // ==================== NEW: Community Post Permissions ====================
            var canPostCommunity = locals.hasPermission('community');
            // ========================================================================

        %>
        <nav class="sidebar" id="sidebar">
            <div class="user-info text-center">
                <h5 class="mb-1"><%= user.employee_name %></h5>
                <small class="text-muted"><%= role %></small>
            </div>
            <div class="sidebar-search">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input id="sidebarSearch" class="form-control" type="search" placeholder="Search menu">
                </div>
            </div>
            <ul class="nav flex-column">
                <li class="sidebar-group-title">My Workspace</li>
                <li class="nav-item"><a class="nav-link" href="/profile"><i class="fas fa-user me-2"></i> My Profile</a></li>
                <li class="nav-item"><a class="nav-link" href="/profile?tab=community"><i class="fas fa-users me-2"></i> Community AVS</a></li>
                <li class="nav-item"><a class="nav-link nav-notification-link" href="/notifications"><i class="fas fa-bell me-2"></i> Notifications <span id="sidebarNotifBadge" class="nav-notification-badge" style="<%= (locals.notificationsUnreadCount || 0) > 0 ? '' : 'display:none;' %>"><%= (locals.notificationsUnreadCount || 0) > 99 ? '99+' : '+' + (locals.notificationsUnreadCount || 0) %></span></a></li>
                <li class="nav-item"><a class="nav-link" href="/structure"><i class="fas fa-sitemap me-2"></i> Structure</a></li>
                <li class="nav-item"><a class="nav-link" href="/salary/my"><i class="fas fa-money-bill-wave me-2"></i> Salary Monthly</a></li>
                <% if (locals.hasPermission('appraisal_team')) { %>
                <li class="nav-item"><a class="nav-link" href="/appraisal_team"><i class="fas fa-clipboard-check me-2"></i> Appraisl Team</a></li>
                <% } %>
                <% if (showLeavesLink) { %>
                <li class="nav-item"><a class="nav-link" href="/leaves"><i class="fas fa-calendar-alt me-2"></i> Leaves</a></li>
                <% } %>
                <% if (locals.hasPermission('hr_movements')) { %>
                <li class="nav-item"><a class="nav-link" href="/profile?tab=movements"><i class="fas fa-exchange-alt me-2"></i> Movements</a></li>
                <% } %>
                
                <% if (hasHrMenu) { %>
                <li class="sidebar-group-title sidebar-group">HR</li>
                <% if (locals.hasPermission('dashboard')) { %>
                <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a></li>
                <% } %>
                <% if (locals.hasPermission('hr_inbox')) { %>
                <li class="nav-item"><a class="nav-link" href="/hr_inbox"><i class="fas fa-inbox me-2"></i> HR Inbox <% if ((locals.hrInboxPendingCount || 0) > 0) { %><span class="nav-count-badge"><%= locals.hrInboxPendingCount > 99 ? '99+' : locals.hrInboxPendingCount %></span><% } %></a></li>
                <% } %>
                <% if (locals.hasPermission('hr_manager')) { %>
                <li class="nav-item"><a class="nav-link" href="/hr_manager"><i class="fas fa-users-cog me-2"></i> HR Manager</a></li>
                <% } %>
                <% if (locals.hasPermission('reports')) { %>
                <li class="nav-item"><a class="nav-link" href="/reports"><i class="fas fa-chart-bar me-2"></i> Reports</a></li>
                <% } %>
                <% if (locals.hasPermission('employee_photos')) { %>
                <li class="nav-item"><a class="nav-link" href="/employee_photos"><i class="fas fa-images me-2"></i> Employee Photos</a></li>
                <% } %>
                <% if (locals.hasPermission('ask_employees')) { %>
                <li class="nav-item"><a class="nav-link" href="/ask_employees"><i class="fas fa-paper-plane me-2"></i> Ask Employees</a></li>
                <% } %>
                
                <!-- Modified Condition for Community Post Link -->
                <% if (canPostCommunity) { %>
                <li class="nav-item"><a class="nav-link" href="/community/create"><i class="fas fa-plus-circle me-2"></i> Community Post</a></li>
                <% } %>
                
                <% if (locals.hasPermission('recruitment')) { %>
