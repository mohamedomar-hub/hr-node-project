<!-- File: views/auth/reset_password.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - HR System</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .reset-wrapper {
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }

        .reset-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            padding: 40px;
            text-align: center;
            border-top: 5px solid #00509e;
        }

        .company-logo {
            max-height: 70px;
            margin-bottom: 25px;
        }

        .form-control {
            border-radius: 6px;
            padding: 12px;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            margin-bottom: 15px;
        }

        .btn-reset {
            background-color: #00509e;
            color: white;
            border: none;
            border-radius: 6px;
            padding: 12px;
            font-weight: bold;
            width: 100%;
            transition: all 0.3s;
        }

        .btn-reset:hover {
            background-color: #003366;
        }

        .back-link {
            display: block;
            margin-top: 15px;
            font-size: 14px;
            color: #00509e;
            text-decoration: none;
        }
        
        .footer-text {
            margin-top: 25px;
            color: #adb5bd;
            font-size: 12px;
        }
    </style>
</head>
<body>

<div class="reset-wrapper">
    <div class="reset-card">
        <img src="/static/images/averroes_logo.png" alt="Logo" class="company-logo" onerror="this.style.display='none'">
        <h4 class="mb-4 text-dark">Reset Password</h4>

        <% if (typeof messages !== 'undefined' && messages) { %>
            <% if (messages.danger) { %><div class="alert alert-danger p-2 mb-3"><%= messages.danger %></div><% } %>
            <% if (messages.success) { %><div class="alert alert-success p-2 mb-3"><%= messages.success %></div><% } %>
        <% } %>

        <form action="/password/reset" method="POST">
            <div class="mb-2">
                <input type="text" name="employee_code" class="form-control" placeholder="Employee Code" required autofocus>
            </div>
            <div class="mb-2">
                <input type="password" name="new_password" class="form-control" placeholder="New Password" required>
            </div>
            <div class="mb-3">
                <input type="password" name="confirm_password" class="form-control" placeholder="Confirm New Password" required>
            </div>
            
            <button type="submit" class="btn btn-reset">Update Password</button>
            
            <a href="/login" class="back-link">Back to Login</a>
        </form>

        <div class="footer-text">&copy; 2026 Averroes Pharma. All rights reserved.</div>
    </div>
</div>

</body>
</html>