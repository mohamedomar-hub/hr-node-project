<% locals.pageTitle = 'IDP Plan & Self Development'; %>

<%
  const selectedDepartments = (existing && existing.selected_departments) || [];
  const strengths = (existing && existing.strengths) || [];
  const developmentAreas = (existing && existing.development_areas) || [];
%>

<div class="container-fluid">
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h3 class="mb-2">Build Your Individual Development Plan</h3>
                <p class="mb-0 text-muted">Identify your strengths, development areas, and the actions that will help you grow.</p>
            </div>
            <span class="badge bg-primary">Up to 2 departments</span>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">Select Departments</div>
        <div class="card-body">
            <form action="/idpMR" method="POST" id="idpForm">
                <div class="row g-3">
                    <% departments.forEach(function(dep, index) { %>
                        <div class="col-md-4 col-sm-6">
                            <label class="d-flex align-items-center gap-2 p-3 border rounded-4 h-100">
                                <input
                                    class="form-check-input mt-0"
                                    type="checkbox"
                                    name="departments"
                                    value="<%= dep %>"
                                    <%= selectedDepartments.includes(dep) ? 'checked' : '' %>
                                >
                                <span class="fw-semibold text-dark"><%= dep %></span>
                            </label>
                        </div>
                    <% }) %>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Development Details</div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-lg-6">
                    <label class="form-label">Strengths</label>
                    <% for (let i = 0; i < 3; i++) { %>
                        <input
                            form="idpForm"
                            name="strength<%= i + 1 %>"
                            class="form-control mb-3"
                            value="<%= strengths[i] || '' %>"
                            placeholder="Strength <%= i + 1 %>"
                        >
                    <% } %>
                </div>
                <div class="col-lg-6">
                    <label class="form-label">Development Areas</label>
                    <% for (let i = 0; i < 3; i++) { %>
                        <input
                            form="idpForm"
                            name="dev<%= i + 1 %>"
                            class="form-control mb-3"
                            value="<%= developmentAreas[i] || '' %>"
                            placeholder="Development Area <%= i + 1 %>"
                        >
                    <% } %>
                </div>
            </div>

            <div class="mt-2">
                <label class="form-label">Action Plan</label>
                <textarea
                    form="idpForm"
                    name="action"
                    class="form-control"
                    rows="5"
                    placeholder="Outline the steps, timeline, support needed, and target outcome"
                ><%= (existing && existing.action_plan) || '' %></textarea>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button form="idpForm" class="btn btn-primary px-4" type="submit">Save Development Plan</button>
            </div>
        </div>
    </div>
</div>
