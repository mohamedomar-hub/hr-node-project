<!-- File: views/settings/permissions.ejs -->
<% locals.pageTitle = 'Permissions by Role'; %>

<div class="container">
    <h2>Permissions by Role</h2>
    <p class="text-muted">Toggle features per role without changing code.</p>

    <!-- Flash Messages -->
    <% if (typeof messages !== 'undefined' && messages) { %>
        <% if (messages.success) { %><div class="alert alert-success"><%= messages.success %></div><% } %>
        <% if (messages.danger) { %><div class="alert alert-danger"><%= messages.danger %></div><% } %>
    <% } %>

    <form action="/settings/permissions" method="POST">
        <div class="card mb-4">
            <div class="card-header">Select Role(s)</div>
            <div class="card-body">
                <div class="row">
                    <% if (typeof roles !== 'undefined' && roles) { %>
                        <% roles.forEach(function(r) { %>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="role" value="<%= r %>" id="role_<%= r %>" <%= typeof current_role !== 'undefined' && current_role === r ? 'checked' : '' %>>
                                    <label class="form-check-label" for="role_<%= r %>">
                                        <%= r %>
                                    </label>
                                </div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>
                <small class="text-muted">Choose one or more titles to apply the same permissions at once.</small>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">Permissions</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Permission</th>
                                <th style="width: 100px;">Enabled</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% 
                                var currentPerms = [];
                                if (typeof role_current !== 'undefined' && typeof current_role !== 'undefined' && role_current[current_role]) {
                                    currentPerms = role_current[current_role];
                                }
                            %>
                            <% if (typeof all_perms !== 'undefined' && all_perms) { %>
                                <% all_perms.forEach(function(p) { %>
                                    <tr>
                                        <td><%= p %></td>
                                        <td class="text-center">
                                            <input type="checkbox" name="perm" value="<%= p %>" <%= currentPerms.includes(p) ? 'checked' : '' %>>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Save Permissions</button>
    </form>
</div>