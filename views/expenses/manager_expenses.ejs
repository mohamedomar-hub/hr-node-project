<!-- File: views/expenses/manager_expenses.ejs -->
<% locals.pageTitle = pageTitle || 'Pending Expense Approvals'; %>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><%= pageTitle || 'Pending Expense Approvals' %></h2>
            <p class="text-muted mb-0">Requests where you are the current approver.</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <% if (expenses && expenses.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>From</th>
                                <th>To</th>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% expenses.forEach(function(e) { %>
                            <tr>
                                <td>
                                    <strong><%= e.employee_name %></strong><br>
                                    <small class="text-muted"><%= e.employee_code %></small>
                                </td>
                                <td><%= e.from_location %></td>
                                <td><%= e.to_location %></td>
                                <td><%= e.expense_date ? new Date(e.expense_date).toLocaleDateString() : '-' %></td>
                                <td><%= e.allowance_type || '-' %></td>
                                <td><strong><%= e.total %></strong></td>
                                <td><span class="badge bg-warning text-dark"><%= e.status %></span></td>
                                <td>
                                    <form action="/expense/approve" method="POST" class="d-inline">
                                        <input type="hidden" name="id" value="<%= e.id %>">
                                        <button type="submit" name="action" value="Approved" class="btn btn-sm btn-success mb-1">
                                            <i class="fas fa-check"></i> Approve
                                        </button>
                                        <button type="submit" name="action" value="Rejected" class="btn btn-sm btn-danger mb-1">
                                            <i class="fas fa-times"></i> Reject
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-success mb-0">
                    <i class="fas fa-check-circle"></i> No pending approvals right now.
                </div>
            <% } %>
        </div>
    </div>
</div>
