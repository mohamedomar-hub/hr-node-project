<% locals.pageTitle = 'Expenses Report'; %>

<div class="container-fluid">
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h3 class="mb-2">HR Expenses Report</h3>
                <p class="mb-0 text-muted">Review all submitted expense requests and filter them by month and employee title.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <% if (hide) { %>
                    <a href="/expense/report?show=1" class="btn btn-outline-success">Show Data</a>
                <% } else { %>
                    <a href="/expense/report?clear=1" class="btn btn-outline-secondary">Hide Current View</a>
                <% } %>
                <a href="/expense/report/export?<%= new URLSearchParams({ m: selected_month || '', title: selected_title || '' }).toString() %>" class="btn btn-primary">Download Excel</a>
            </div>
        </div>
    </div>

    <% if (hide) { %>
        <div class="alert alert-warning">The expense report is hidden. Click <strong>Show Data</strong> to display records again.</div>
    <% } else { %>
        <div class="card mb-4">
            <div class="card-header">Filters</div>
            <div class="card-body">
                <form method="GET" action="/expense/report" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Month</label>
                        <select name="m" class="form-select">
                            <option value="">All Months</option>
                            <% months.forEach(function(month) { %>
                                <option value="<%= month.value %>" <%= selected_month === month.value ? 'selected' : '' %>><%= month.label %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Title</label>
                        <select name="title" class="form-select">
                            <option value="">All Titles</option>
                            <% titles.forEach(function(title) { %>
                                <option value="<%= title %>" <%= selected_title === title ? 'selected' : '' %>><%= title %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">Apply Filters</button>
                        <a href="/expense/report" class="btn btn-outline-secondary flex-fill">Reset</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Expense Records</div>
            <div class="card-body p-0">
                <% if (expenses && expenses.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Employee</th>
                                    <th>Title</th>
                                    <th>Month</th>
                                    <th>From</th>
                                    <th>To</th>
                                    <th>Days</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th>Current Approver</th>
                                    <th>Manager</th>
                                    <th>Attachment</th>
                                    <th>Updated</th>
                                    <th>Action</th>
                                    <th class="text-end">Delete</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% expenses.forEach(function(expense) { %>
                                    <tr>
                                        <td><%= expense.id %></td>
                                        <td class="fw-semibold">
                                            <%= expense.employee_name || '-' %>
                                            <div class="text-muted small"><%= expense.employee_code %></div>
                                        </td>
                                        <td><%= expense.employee_title || '-' %></td>
                                        <td><%= expense.report_month_label || '-' %></td>
                                        <td><%= expense.from_location || '-' %></td>
                                        <td><%= expense.to_location || '-' %></td>
                                        <td><%= expense.num_days || 1 %></td>
                                        <td class="fw-semibold"><%= expense.total || '0.00' %></td>
                                        <td>
                                            <span class="badge <%= expense.status === 'Approved' ? 'bg-success' : expense.status === 'Rejected' ? 'bg-danger' : 'bg-warning' %>">
                                                <%= expense.status || 'Pending' %>
                                            </span>
                                        </td>
                                        <td><%= expense.current_approver || '-' %></td>
                                        <td>
                                            <% if (expense.manager_name) { %>
                                                <%= expense.manager_name %>
                                                <% if (expense.manager_code) { %>
                                                    <div class="text-muted small"><%= expense.manager_code %></div>
                                                <% } %>
                                            <% } else { %>
                                                <%= expense.manager_code || '-' %>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (expense.attachment_path) { %>
                                                <a href="/<%= expense.attachment_path.replace(/^static[\\/]/, 'static/') %>" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">View</a>
                                            <% } else { %>
                                                <span class="text-muted">-</span>
                                            <% } %>
                                        </td>
                                        <td><%= expense.updated_at_only || expense.created_at_only || '-' %></td>
                                        <td>
                                            <% if (expense.status === 'Pending' && String(expense.current_approver || '') === String(user.employee_code || '')) { %>
                                                <form action="/expense/report/<%= expense.id %>/action?<%= new URLSearchParams({ m: selected_month || '', title: selected_title || '' }).toString() %>" method="POST" class="d-inline">
                                                    <button type="submit" name="action" value="Approved" class="btn btn-sm btn-success mb-1">Approve</button>
                                                    <button type="submit" name="action" value="Rejected" class="btn btn-sm btn-danger mb-1">Reject</button>
                                                </form>
                                            <% } else { %>
                                                <span class="text-muted small">-</span>
                                            <% } %>
                                        </td>
                                        <td class="text-end">
                                            <form action="/expense/report/<%= expense.id %>/delete?<%= new URLSearchParams({ m: selected_month || '', title: selected_title || '' }).toString() %>" method="POST" class="m-0 d-inline-block" onsubmit="return confirm('Delete this expense record from the report?');">
                                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="p-4">
                        <div class="alert alert-info mb-0">No expenses found for the selected filters.</div>
                    </div>
                <% } %>
            </div>
        </div>
    <% } %>
</div>
