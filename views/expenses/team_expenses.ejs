<!-- File: views/expenses/team_expenses.ejs -->
<% locals.pageTitle = 'Expenses Team'; %>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Expenses Team</h2>
        <!-- Optional Export Button if needed -->
        <!-- <a href="/expense/export_all" class="btn btn-success">
            <i class="fas fa-file-excel"></i> Export All
        </a> -->
    </div>

    <!-- Pending Requests Section -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">Pending Requests from Your Team</div>
        <div class="card-body">
            <% if (expenses && expenses.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>From</th>
                                <th>To</th>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% expenses.forEach(function(e) { %>
                            <tr>
                                <td>
                                    <strong><%= e.employee_name || e.submitter_name %></strong><br>
                                    <small class="text-muted"><%= e.employee_code %></small>
                                </td>
                                <td><%= e.from_location %></td>
                                <td><%= e.to_location %></td>
                                <td><%= new Date(e.expense_date).toLocaleDateString() %></td>
                                <td><%= e.allowance_type || e.expense_type %></td>
                                <td><strong><%= e.total %></strong></td>
                                <td><span class="badge bg-warning text-dark"><%= e.status %></span></td>
                                <td>
                                    <!-- Form for Approval/Rejection -->
                                    <form action="/expense/approve" method="POST" class="d-inline">
                                        <input type="hidden" name="id" value="<%= e.id %>">
                                        
                                        <button type="submit" name="action" value="Approved" class="btn btn-sm btn-success mb-1">
                                            <i class="fas fa-check"></i> Approve
                                        </button>
                                        <button type="submit" name="action" value="Rejected" class="btn btn-sm btn-danger mb-1">
                                            <i class="fas fa-times"></i> Reject
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info">No pending requests from your team.</div>
            <% } %>
        </div>
    </div>
</div>