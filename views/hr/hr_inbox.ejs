<!-- File: views/hr/hr_inbox.ejs -->
<% locals.pageTitle = 'HR Inbox - Ask HR Messages'; %>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-inbox me-2"></i>HR Inbox (Ask HR)</h2>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted">Messages sent to you by employees</span>
            <!-- ✅ زرار تحميل Excel -->
            <a href="/hr_inbox/export" class="btn btn-success btn-sm">
                <i class="fas fa-file-excel me-2"></i>Export to Excel
            </a>
        </div>
    </div>

    <!-- Flash Messages -->
    <% if (typeof messages !== 'undefined' && messages) { %>
        <% if (messages.success) { %><div class="alert alert-success alert-dismissible fade show"><%= messages.success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
        <% if (messages.danger) { %><div class="alert alert-danger alert-dismissible fade show"><%= messages.danger %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
    <% } %>

    <% if (typeof messages_list !== 'undefined' && messages_list && messages_list.length > 0) { %>
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 15%;">Date</th>
                        <th style="width: 20%;">From (Employee)</th>
                        <th style="width: 35%;">Message / Inquiry</th>
                        <th style="width: 10%;">Status</th>
                        <th style="width: 20%;">Reply & Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% messages_list.forEach(function(m) { 
                        var statusClass = '';
                        if (m.status === 'New')     statusClass = 'bg-warning text-dark';
                        if (m.status === 'Read')    statusClass = 'bg-secondary text-white';
                        if (m.status === 'Replied') statusClass = 'bg-success text-white';
                    %>
                    <tr>
                        <td>
                            <%= new Date(m.created_at).toLocaleDateString('en-US', {
                                year: 'numeric', month: 'short', day: 'numeric',
                                hour: '2-digit', minute: '2-digit'
                            }) %>
                        </td>
                        <td>
                            <strong><%= m.sender_name %></strong><br>
                            <small class="text-muted">Code: <%= m.sender_code %></small>
                        </td>
                        <td>
                            <p class="mb-1"><%= m.message %></p>
                            <% if (m.reply) { %>
                                <hr class="my-2">
                                <div class="bg-light p-2 rounded border-start border-4 border-primary">
                                    <strong>HR Reply:</strong><br>
                                    <%= m.reply %>
                                </div>
                            <% } %>
                        </td>
                        <td>
                            <span class="badge <%= statusClass %>"><%= m.status %></span>
                        </td>
                        <td>
                            <form action="/hr_inbox/reply/<%= m.id %>" method="POST">
                                <textarea name="reply_text" class="form-control form-control-sm mb-2"
                                    rows="2" placeholder="Write your reply..."></textarea>
                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                    <i class="fas fa-paper-plane"></i> Send Reply
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>No new messages in your inbox.
        </div>
    <% } %>
</div>
