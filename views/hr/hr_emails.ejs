<% locals.pageTitle = 'Personal Emails'; %>

<div class="container-fluid">
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h3 class="mb-2">Personal Emails</h3>
                <p class="mb-0 text-muted">Submitted personal and Facebook emails from employees.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <% if (hide) { %>
                    <a class="btn btn-outline-success" href="/hr_emails?show=1">Show Data</a>
                <% } else { %>
                    <a class="btn btn-outline-secondary" href="/hr_emails?clear=1">Hide Current View</a>
                <% } %>
                <a class="btn btn-primary" href="/hr_emails/export">Download Excel</a>
            </div>
        </div>
    </div>

    <% if (hide) { %>
        <div class="alert alert-info">The personal emails view is hidden. Use <strong>Show Data</strong> to display records again.</div>
    <% } else if (emails && emails.length > 0) { %>
        <div class="card">
            <div class="card-header">Submitted Personal Emails</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Title</th>
                                <th>Department</th>
                                <th>Email</th>
                                <th>Facebook Email</th>
                                <th>Updated</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% emails.forEach(function(email) { %>
                                <tr>
                                    <td><%= email.employee_code %></td>
                                    <td class="fw-semibold"><%= email.employee_name %></td>
                                    <td><%= email.title || '-' %></td>
                                    <td><%= email.department || '-' %></td>
                                    <td><%= email.email || '-' %></td>
                                    <td><%= email.facebook_email || '-' %></td>
                                    <td><%= email.updated_at ? formatDisplayDate(email.updated_at) : '-' %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="alert alert-info">No personal emails submitted yet.</div>
    <% } %>
</div>
