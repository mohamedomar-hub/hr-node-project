<!-- File: views/hr/request_hr.ejs -->
<% locals.pageTitle = 'HR Communicate Center'; %>

<div class="container-fluid">
    <h2><i class="fas fa-envelope-open-text me-2"></i>HR Communicate Center</h2>
    
    <!-- Flash Messages -->
    <% if (typeof messages !== 'undefined' && messages) { %>
        <% if (messages.success) { %><div class="alert alert-success"><%= messages.success %></div><% } %>
        <% if (messages.danger) { %><div class="alert alert-danger"><%= messages.danger %></div><% } %>
    <% } %>

    <!-- Tabs Navigation -->
    <ul class="nav nav-tabs mb-4" id="hrRequestTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="inbox-tab" data-bs-toggle="tab" data-bs-target="#inbox" type="button" role="tab" aria-controls="inbox" aria-selected="true">
                <i class="fas fa-inbox me-1"></i> Inbox
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="docs-tab" data-bs-toggle="tab" data-bs-target="#docs" type="button" role="tab" aria-controls="docs" aria-selected="false">
                <i class="fas fa-file-upload me-1"></i> Document Requests
            </button>
        </li>
    </ul>

    <!-- Tabs Content -->
    <div class="tab-content" id="hrRequestTabsContent">
        
        <!-- Tab 1: Inbox -->
        <div class="tab-pane fade show active" id="inbox" role="tabpanel" aria-labelledby="inbox-tab">
            <% if (typeof ask_hr_replies !== 'undefined' && ask_hr_replies && ask_hr_replies.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 15%;">Date</th>
                                <th style="width: 20%;">From / To</th>
                                <th style="width: 35%;">Message</th>
                                <th style="width: 20%;">Reply</th>
                                <th style="width: 10%;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% ask_hr_replies.forEach(function(m) { %>
                            <tr>
                                <td><%= new Date(m.updated_at || m.created_at).toLocaleDateString() %></td>
                                <td>
                                    <% if (m.inbox_type === 'direct') { %>
                                        <%= m.sender_name %>
                                    <% } else { %>
                                        <%= m.recipient_name %>
                                    <% } %>
                                </td>
                                <td style="white-space: pre-line;"><%= m.message %></td>
                                <td class="bg-light p-2" style="white-space: pre-line;"><%= m.reply || '-' %></td>
                                <td>
                                    <form action="/request_hr/delete_message/<%= m.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this message?');">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info">No messages yet.</div>
            <% } %>
        </div>

        <!-- Tab 2: Document Requests -->
        <div class="tab-pane fade" id="docs" role="tabpanel" aria-labelledby="docs-tab">
            <% if (typeof doc_requests !== 'undefined' && doc_requests && doc_requests.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 10%;">Date</th>
                                <th style="width: 15%;">Requested By (HR)</th>
                                <th style="width: 15%;">Document Type</th>
                                <th style="width: 25%;">Message / Instructions</th>
                                <th style="width: 15%;">Attached File</th> <!-- New Column for File -->
                                <th style="width: 10%;">Status</th>
                                <th style="width: 10%;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% doc_requests.forEach(function(r) { %>
                            <tr>
                                <td><%= new Date(r.created_at).toLocaleDateString() %></td>
                                <td><%= r.requested_by_name %></td>
                                <td><strong><%= r.document_type %></strong></td>
                                <td>
                                    <% if (r.message || r.description) { %>
                                        <span style="white-space: pre-line;"><%= r.message || r.description %></span>
                                    <% } else { %>
                                        <span class="text-muted">No details</span>
                                    <% } %>
                                </td>
                                
                                <!-- Column for Attached File -->
                                <td>
                                    <% if (r.attachment_path) { %>
                                        <a href="/<%= r.attachment_path %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-download"></i> View/Download
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted small">No file</span>
                                    <% } %>
                                </td>

                                <td>
                                    <% if (r.status === 'Pending') { %>
                                        <span class="badge bg-warning">Pending</span>
                                    <% } else if (r.status === 'Submitted') { %>
                                        <span class="badge bg-info">Submitted</span>
                                    <% } else if (r.status === 'Approved') { %>
                                        <span class="badge bg-success">Approved</span>
                                    <% } else if (r.status === 'Rejected') { %>
                                        <span class="badge bg-danger">Rejected</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary"><%= r.status %></span>
                                    <% } %>
                                </td>
                                <td>
                                    <!-- Upload Form if Pending -->
                                    <% if (r.status === 'Pending') { %>
                                        <form action="/request_hr/submit_doc/<%= r.id %>" method="POST" enctype="multipart/form-data" class="mb-1">
                                            <input type="file" name="document_file" class="form-control form-control-sm mb-1" required accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                                            <button type="submit" class="btn btn-sm btn-primary w-100">
                                                <i class="fas fa-upload"></i> Upload
                                            </button>
                                        </form>
                                    <% } %>
                                    
                                    <!-- Delete Button -->
                                    <form action="/request_hr/delete_doc_request/<%= r.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this request?');">
                                        <button type="submit" class="btn btn-sm btn-danger w-100">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info">No document requests from HR.</div>
            <% } %>
        </div>

    </div>
</div>
