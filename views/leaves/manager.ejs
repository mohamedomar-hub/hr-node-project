<!-- File: views/leaves/manager.ejs -->
<!-- تم إزالة include و block ليتوافق مع express-ejs-layouts -->

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <!-- Page Header -->
            <div class="page-header">
                <span class="page-label">Management</span>
                <h1 class="page-title">Team Leave Requests</h1>
            </div>

            <!-- Pending Requests -->
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-clock me-2"></i>Pending Approvals</h5>
                    <% if (leaves && leaves.length > 0) { %>
                        <span class="badge bg-danger"><%= leaves.length %></span>
                    <% } %>
                </div>
                <div class="card-body">
                    <% if (leaves && leaves.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Employee</th>
                                        <th>Type</th>
                                        <th>Start Date</th>
                                        <th>End Date</th>
                                        <th>Days</th>
                                        <th>Status</th>
                                        <th class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% leaves.forEach(function(row) { 
                                        // Calculate days for display
                                        var start = new Date(row.start_date);
                                        var end = new Date(row.end_date);
                                        var diffTime = Math.abs(end - start);
                                        var diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1; 
                                    %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="fw-bold"><%= row.employee_name || row.employee_code %></div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-info text-dark"><%= row.leave_type %></span></td>
                                        <td><%= row.start_date %></td>
                                        <td><%= row.end_date %></td>
                                        <td><strong><%= diffDays %></strong></td>
                                        <td><span class="badge bg-warning text-dark"><%= row.status %></span></td>
                                        <td class="text-center">
                                            <a href="/leave/approve/<%= row.id %>" class="btn btn-sm btn-success me-1" onclick="return confirm('Are you sure you want to approve this leave?')">
                                                <i class="fas fa-check"></i> Approve
                                            </a>
                                            <a href="/leave/reject/<%= row.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to reject this leave?')">
                                                <i class="fas fa-times"></i> Reject
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="fas fa-check-circle fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No pending requests found.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- History -->
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-history me-2"></i>History (Approved/Rejected)</h5>
                </div>
                <div class="card-body">
                    <%
                    var historyRows = history ? history.filter(function(r) { return r.status !== 'Pending'; }) : [];
                    %>
                    <% if (historyRows.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Employee</th>
                                        <th>Type</th>
                                        <th>Start</th>
                                        <th>End</th>
                                        <th>Status</th>
                                        <th>Decision Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% historyRows.forEach(function(row) { %>
                                    <tr>
                                        <td><strong><%= row.employee_name || row.employee_code %></strong></td>
                                        <td><%= row.leave_type %></td>
                                        <td><%= row.start_date %></td>
                                        <td><%= row.end_date %></td>
                                        <td>
                                            <span class="badge <%= row.status === 'Approved' ? 'bg-success' : 'bg-danger' %>">
                                                <%= row.status %>
                                            </span>
                                        </td>
                                        <td class="text-muted small"><%= row.decision_date ? new Date(row.decision_date).toLocaleDateString() : '-' %></td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center py-3">No approved or rejected requests yet.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Auto-hide flash messages after 3 seconds
    setTimeout(function() {
        var alerts = document.querySelectorAll('.alert-dismissible');
        alerts.forEach(function(alert) {
            alert.style.transition = 'opacity 0.5s';
            alert.style.opacity = '0';
            setTimeout(function() { alert.remove(); }, 500);
        });
    }, 3000);
</script>