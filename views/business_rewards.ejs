<!-- File: views/business_rewards.ejs -->
<% locals.pageTitle = 'Business Rewards'; %>

<style>
  /* General Table Styles */
  .rewards-table {
    width: 100%;
    border-collapse: collapse;
    font-family: Arial, sans-serif;
    margin-bottom: 30px;
  }
  .rewards-table th {
    background-color: #8B0000; /* Dark Red Header */
    color: white;
    padding: 10px;
    text-align: center;
    border: 1px solid #ddd;
  }
  .rewards-table td {
    padding: 8px;
    border: 1px solid #ddd;
    vertical-align: middle;
  }
  .rewards-table tr:nth-child(even) {
    background-color: #f9f9f9;
  }
  .rewards-table tr:hover {
    background-color: #e6f7ff;
  }

  /* Specific Styles for Champions Table (Bottom Table) */
  .champions-table {
    width: 100%;
    border-collapse: collapse;
    font-family: Arial, sans-serif;
    margin-top: 20px;
  }
  .champions-table th {
    background-color: #8B0000; /* Keep header red */
    color: white;
    padding: 10px;
    text-align: center;
    border: 1px solid #ddd;
  }
  .champions-table td {
    background-color: #003366 !important; /* Dark Blue Background for all cells */
    color: white !important; /* White Text Default */
    padding: 10px;
    border: 1px solid #ddd;
    vertical-align: middle;
  }
  /* Gold/Yellow Text for specific items */
  .champions-table .gold-text {
    color: #FFD700 !important;
    font-weight: bold;
  }

  /* Title and Logo Styles */
  .reward-title {
    background-color: #003366; /* Dark Blue */
    color: white;
    padding: 15px;
    font-size: 24px;
    font-weight: bold;
    text-align: center;
    margin-bottom: 20px;
    border-radius: 5px;
  }
  .company-logo {
    text-align: center;
    margin-top: 20px;
  }
  .company-logo img {
    max-width: 200px;
  }
</style>

<div class="container-fluid">
